            { "displayTitle": "An Historical Defense of the Exodus - Part 2", "filename": "An Historical Defense of the Exodus & Conquest (Part 2) - Sandra Richter___99.mp3" }
          ]
        },
        {
          "id": "men-women-bible",
          "title": "Men, Women, and the Bible",
          "titleBgColor": "bg-sky-500",
          "description": "For many today, the Bible's view of gender is a hot-button issue. Collected here are lectures on some of the most controversial passages on the genders as well as an overall framework for answering questions that often come up.",
          "backgroundImage": "/images/playlists/men-women-bible-bg.avif",
          "tracks": [
            { "displayTitle": "Is Go                         d Angry", "filename": "Are We Better Than God^ part 3_ Is God Angry^ - Wade Bradshaw___130.mp3" },
            { "displayTitle": "An Historical Defense of the Exodus - Part 1", "filename": "An Historical Defense of the Exodus & Conquest (Part 1) - Sandra Richter___98.mp3" },
            { "displayTitle": "An Historical Defense of the Exodus - Part 2", "filename": "An Historical Defense of the Exodus & Conquest (Part 2) - Sandra Richter___99.mp3" }
          ]
        },
        {
          "id": "navigating-relationships",
          "title": "Navigating Relationships",
          "titleBgColor": "bg-orange-600",
          "description": "What does it mean to be alone? To be with others? To be a friend? To be married? These lectures talk about the many questions that come up as we dance the steps of relationship.",
          "backgroundImage": "/images/playlists/navigating-relationships-bg.avif",
          "tracks": [
            { "displayTitle": "Is God Angry", "filename": "Are We Better Than God^ part 3_ Is God Angry^ - Wade Bradshaw___130.mp3" },
            { "displayTitle": "An Historical Defense of the Exodus - Part 1", "filename": "An Historical Defense of the Exodus & Conquest (Part 1) - Sandra Richter___98.mp3" },
            { "displayTitle": "An Historical Defense of the Exodus - Part 2", "filename": "An Historical Defense of the Exodus & Conquest (Part 2) - Sandra Richter___99.mp3" }
          ]
        },
        {
          "id": "literature-poetry",
          "title": "Literature and Poetry",
          "titleBgColor": "bg-amber-400",
          "description": "If Christ is Lord of all of life, the domain of the written word should be the concern of Christ's followers. Here is a collection of lectures on Flannery O'Connor, T. S. Eliot, Tolkien, Rowling, and more.",
