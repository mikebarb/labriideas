---
import Layout from '../layouts/Layout.astro';
import Downloader from '../components/downloader.svelte';
---

<Layout>
  <main class="flex flex-col items-center py-12">
    <h1 class="text-4xl font-bold text-white mb-8 text-center">Fetch from R2</h1>
    <p class="text-slate-300 mb-8 text-center max-w-lg">This requests a secure, time-limited signed URL from our Go server, then downloads the file directly from Cloudflare R2.</p>
    
    <Downloader client:load />
  </main>
</Layout>
