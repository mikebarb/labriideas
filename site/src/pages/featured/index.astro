---
// src/pages/featured/index.astro
import Layout from '../../layouts/LabriLayout.astro';
import menuData from '../../data/menu.json';

// Pull the featured lectures data (with defensive fallback)
const featuredData = menuData.featuredLectures ?? { 
  sectionTitle: "Featured Lectures", 
  sectionSubtitle: "", 
  items: [] 
};
const { sectionTitle, sectionSubtitle, items } = featuredData;
---

<Layout title="Featured Lectures">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-gray-900">{sectionTitle}</h1>
    {sectionSubtitle && <p class="text-gray-600 mb-8">{sectionSubtitle}</p>}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map(item => (
        <button 
          type="button"
          data-featured-id={item.id}
          data-filename={item.filename}
          data-title={item.title}
          data-speaker={item.speaker}
          class="block relative h-48 rounded-lg overflow-hidden bg-cover bg-center group w-full text-left cursor-pointer border-0 p-0"
          style={`background-image: url(${item.image})`}
        >
          <div class="absolute inset-0 bg-black/60 group-hover:bg-black/40 transition p-4 flex flex-col justify-end">
            <h2 class="text-white text-xl font-bold">{item.title}</h2>
            <p class="text-gray-200 text-sm mt-1">{item.speaker}</p>
          </div>
        </button>
      ))}
    </div>
  </div>

  <script>
    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest('[data-featured-id]') as HTMLButtonElement;
      
      if (button) {
        event.preventDefault();
        // Build a Track object that matches Player.svelte's expectations
        const track = {
          id: button.dataset.featuredId,
          filename: button.dataset.filename,
          hash: '',     //Not used for featured lectures
          metadata: {
            title: button.dataset.title,
            artist: button.dataset.speaker,
            speaker: button.dataset.speaker
          },
          title: button.dataset.title,
          artist: button.dataset.speaker,
          speaker: button.dataset.speaker,
          playbackRate: 1.0
        };    
        
        // Dispatch the event the Player is already listening for
        window.dispatchEvent(new CustomEvent('play-track', { 
          detail: track 
        }));
      }
    });
  </script>
</Layout>
