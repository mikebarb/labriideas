---
import LabriLayout from '../../layouts/LabriLayout.astro';
import SchaefferGrid from '../../components/SchaefferGrid.svelte';
import menuData from '../../data/menu.json';
import Hero from '../../components/Hero.svelte';

// Extract the collection data with a safe fallback
const data = menuData.schaefferCollection ?? {
  sectionTitle: "The Schaeffer Collection",
  sectionSubtitle: "",
  sectionImage: "",
  people: {}
};

const { sectionTitle, sectionSubtitle, sectionImage, people } = data;
---

<LabriLayout title={sectionTitle}>
<!-- Hero Section with Blurred Background -->
  <Hero
    title={sectionTitle}
    subtitle={sectionSubtitle || undefined}
    backgroundImage={sectionImage}
    height="h-[300px]"
    showBrushStroke={false}
    blurBackground={true}
  />

  <!-- Two Column Grid -->
  <div class="container mx-auto px-4 py-12">
    <SchaefferGrid people={people} client:load />
  </div>
</LabriLayout>
