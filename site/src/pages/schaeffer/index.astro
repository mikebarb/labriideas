---
import LabriLayout from '../../layouts/LabriLayout.astro';
import SchaefferGrid from '../../components/SchaefferGrid.svelte';
import menuData from '../../data/menu.json';

// Extract the collection data with a safe fallback
const data = menuData.schaefferCollection ?? {
  sectionTitle: "The Schaeffer Collection",
  sectionSubtitle: "",
  sectionImage: "",
  people: {}
};

const { sectionTitle, sectionSubtitle, sectionImage, people } = data;
---

<LabriLayout title={sectionTitle}>
  <!-- Hero Section with Blurred Background -->
  <header class="relative w-full h-80 md:h-96 overflow-hidden">
    {sectionImage && (
      <img 
        src={sectionImage} 
        alt="" 
        class="absolute inset-0 w-full h-full object-cover"
        style="filter: blur(8px);"
        loading="eager"
      />
    )}
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative h-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col justify-center items-center text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{sectionTitle}</h1>
      {sectionSubtitle && <p class="text-lg text-gray-200 max-w-2xl">{sectionSubtitle}</p>}
    </div>
  </header>

  <!-- Two Column Grid -->
  <div class="container mx-auto px-4 py-12">
    <SchaefferGrid people={people} client:load />
  </div>
</LabriLayout>
