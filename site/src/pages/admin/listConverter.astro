---
import Layout from '../../layouts/LayoutAdmin.astro';
import ListConverter from '../../components/ListConverter.svelte'; 
---

<Layout>
  <main class="flex flex-col items-center py-12">
    <h1 class="text-4xl font-bold text-white mb-8 text-center">Catalogue Maker</h1>
    <p class="text-slate-300 mb-8 text-center max-w-lg">To build a compressed catalogue from the exported excel text ready for uploading to R2 storage.</p>

    <ListConverter client:load />

</main>
</Layout>
