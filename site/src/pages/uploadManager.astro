---
import Layout from '../layouts/Layout.astro';
import UploadManager from '../components/UploadManager.svelte';
---

<Layout>
  <main class="flex flex-col items-center py-12">
    <h1 class="text-4xl font-bold text-white mb-8 text-center">Upload Manager</h1>
    <p class="text-slate-300 mb-8 text-center max-w-lg">Select an audio file, add metadata and upload to R2.</p>
    
    <UploadManager client:load />
  </main>
</Layout>
