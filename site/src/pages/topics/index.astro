---
import LabriLayout from '../../layouts/LabriLayout.astro';
import TopicsTree from '../../components/TopicsTree.svelte';
import menuData from '../../data/menu.json';

// Get the Topics hierarchy from menu.json
const topicsMenu: any = menuData.subMenus.find((s: any) => s.subMenu === 'Topics');

// Cast the hierarchy to match the Props type, with safe fallback
const hierarchy: Record<string, Record<string, Array<{ subtopic: string; category: string }>>> = 
  topicsMenu?.hierarchy || {};
---

<LabriLayout title="Topics">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-center">Ideas Library Topics</h1>
    <TopicsTree client:load />
  </div>
</LabriLayout>
