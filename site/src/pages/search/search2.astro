---
// src/pages/search2.astro
import LabriLayout from '../../layouts/LabriLayout.astro';
import SearchFilter2 from '../../components/SearchFilter2.svelte';
import SearchResults2 from '../../components/SearchResults2.svelte';
---

<LabriLayout title="Search (Option 2)">
  <div class="max-w-4xl mx-auto px-4 py-4">
    <h1 class="text-3xl font-bold mb-6 text-gray-900">Search Library: Option 2</h1>
    
    <div class="sticky top-20 z-40 bg-white/95 backdrop-blur-sm pb-4 border-b border-gray-200">
      <SearchFilter2 client:load />
    </div>

    <div class="pt-4">
      <SearchResults2 client:load />
    </div>
  </div>
</LabriLayout>
