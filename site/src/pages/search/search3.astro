---
// src/pages/search3.astro
import LabriLayout from '../../layouts/LabriLayout.astro';
import SearchFilter3 from '../../components/SearchFilter3.svelte';
import SearchResults3 from '../../components/SearchResults3.svelte';

// Define apiBase from environment. This is the same pattern 
// used elsewhere in the app (e.g., LabriLayout.astro passes it to Player).
const apiBase = import.meta.env.PUBLIC_API_BASE_URL;
---

<LabriLayout title="Search (Option 3)">
  <div class="max-w-4xl mx-auto px-4 py-4">
    <h1 class="text-3xl font-bold text-gray-900">Search Library</h1>
    
    <div class="sticky top-0 z-40 bg-white/95 pt-4 backdrop-blur-sm pb-4 border-b border-gray-200">
      <SearchFilter3 client:load />
    </div>

    <div class="pt-4">
       <SearchResults3 client:load {apiBase} />
    </div>
  </div>
</LabriLayout>
