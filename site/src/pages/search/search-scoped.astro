---
import LabriLayout from '../../layouts/LabriLayout.astro';
import ScopedSearch from '../../components/ScopedSearch.svelte';
import ScopedResults from '../../components/ScopedResults.svelte';

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || '';
---

<LabriLayout title="Scoped Search">
  <div class="max-w-4xl mx-auto px-4 py-4">
    <ScopedSearch client:load />
    <div class="pt-4">
      <ScopedResults client:load apiBase={apiBase} />
    </div>
  </div>
</LabriLayout>
