---
// src/pages/search/index.astro
import LabriLayout from '../../layouts/LabriLayout.astro';
import SearchFilter from '../../components/SearchFilter.svelte';
import SearchResults from '../../components/SearchResults.svelte';
---

<LabriLayout title="Search Library">
  <div class="max-w-4xl mx-auto px-4 py-4">
    <h1 class="text-3xl font-bold mb-6 text-gray-900">Search & Discover</h1>
    
    <!-- The Search Filter bar stays sticky under the navbar -->
    <div class="sticky top-20 z-40 bg-white/95 backdrop-blur-sm pb-4 border-b border-gray-200">
      <SearchFilter client:load />
    </div>

    <!-- The Results list -->
    <div class="pt-4">
      <SearchResults client:load />
    </div>
  </div>
</LabriLayout>
