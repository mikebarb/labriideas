---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex flex-col items-centerąc py-12 gap-12">
    <h1 class="text-4xl font-bold text-white text text-center">Admin Dashboard</h1>
    <p class="text-slate-300 mb-8 text-center max-w-lg">Manage files in your R2 Bucket.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-4xl px-4">
      <a href="/uploader" class="text-lg font-semibold hover:text-cyan-300 transition-colors text-cyan-400">
		    uploader
	    </a>
      <a href="/downloader" class="text-lg font-semibold hover:text-cyan-300 transition-colors text-slate-300">
		    downloader
	    </a>
      <a href="/catalogViewer" class="text-lg font-semibold hover:text-cyan-300 transition-colors text-slate-300">
		    Catalogue Viewer
	    </a>
      <a href="/listConverter" class="text-lg font-semibold hover:text-cyan-300 transition-colors text-slate-300">
		    List Converter
	    </a>
      <a href="/CsvToJson" class="text-lg font-semibold hover:text-cyan-300 transition-colors text-slate-300">
				Tool - CsvToJson
			</a>
    </div>
  </main>
</Layout>
