---
import Layout from '../../layouts/LabriLayout.astro';
import menuData from '../../data/menu.json';
import Hero from '../../components/Hero.svelte';

// Defensive: handle both old (flat) and new (subMenus) menu.json structures
const albums = menuData.subMenus.find(s => s.subMenu === 'Playlists')?.albums ?? [];
---

<Layout title="Playlists">
  <Hero
    title="Playlists"
    subtitle="Selected lectures grouped by theme."
    backgroundImage={import.meta.env.BASE_URL + "images/using-the-ideas-library-bg.avif"}
    height="h-[300px]"
    showBrushStroke={false}
  />
  
  <div class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {albums.map(album => (
        album.linkToForm && !album.tracks ? (
          <a 
            href={album.linkToForm}
            target="_blank"
            rel="noopener noreferrer"
            class="block relative h-48 rounded-lg overflow-hidden bg-cover bg-center group"
            style={`background-image: url(${album.backgroundImage})`}
          >
            <div class="absolute inset-0 bg-black/60 group-hover:bg-black/40 transition p-4 flex flex-col justify-end">
              <h2 class="text-white text-xl font-bold">{album.title}</h2>
              <p class="text-gray-200 text-sm mt-1">{album.description}</p>
            </div>
          </a>
        ) : (
          <a 
            href={`/playlists/${album.id}/`}
            class="block relative h-48 rounded-lg overflow-hidden bg-cover bg-center group"
            style={`background-image: url(${album.backgroundImage})`}
          >
            <div class="absolute inset-0 bg-black/60 group-hover:bg-black/40 transition p-4 flex flex-col justify-end">
              <h2 class="text-white text-xl font-bold">{album.title}</h2>
              <p class="text-gray-200 text-sm mt-1">{album.description}</p>
            </div>
          </a>
        )
      ))}
    </div>
  </div>
</Layout>
