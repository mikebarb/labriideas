---
// src/layouts/LabriLayout.astro
import '../styles/global.css';
import Navbar from '../components/Navbar.svelte';
import MegaMenu from '../components/MegaMenu.svelte';
import Player from '../components/Player.svelte';

// 1. Import the static configuration
import menuData from '../data/menu.json';

// 2. Extract the Topics hierarchy (with the type guard for safety)
const topicsSubMenu = menuData.subMenus.find(s => s.subMenu === 'Topics');
if (!topicsSubMenu || !topicsSubMenu.hierarchy) {
  throw new Error('Configuration error: "Topics" subMenu with hierarchy not found in menu.json');
}
const topicsHierarchy = topicsSubMenu.hierarchy;

interface Props {
	title: string;
}

const { title } = Astro.props;
const isHome = Astro.url.pathname === '/';
const showMegaMenu = isHome;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | L'Abri Ideas Library</title>
	</head>
    <!-- Note the white background and dark text for the L'Abri site -->
	<body class="bg-white text-gray-900 font-sans min-h-screen flex flex-col">
		<Navbar client:load />
		<!-- {showMegaMenu && <MegaMenu client:load />}  -->
		<!-- 3. Pass the hierarchy as a prop instead of letting the component import it -->
    	{showMegaMenu && <MegaMenu hierarchy={topicsHierarchy} client:load />}
		
		<main class="flex-1">
			<slot />
		</main>
		<!-- PLAYER: Visible on all pages, controls its own visibility -->
		<div transition:persist="audio-player">
			<Player 
			client:load 
			showTracklist={false} 
			apiBase={import.meta.env.PUBLIC_API_BASE_URL} 
			isAdmin={true} 
			/>
		</div>
	</body>
</html>
