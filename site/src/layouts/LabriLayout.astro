---
// src/layouts/LabriLayout.astro
import '../styles/global.css';
import Navbar from '../components/Navbar.svelte';
import MegaMenu from '../components/MegaMenu.svelte';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | L'Abri Ideas Library</title>
	</head>
    <!-- Note the white background and dark text for the L'Abri site -->
	<body class="bg-white text-gray-900 font-sans min-h-screen flex flex-col">
		<Navbar client:load />
		<MegaMenu client:load />
		
		<main class="flex-1">
			<slot />
		</main>
	</body>
</html>
