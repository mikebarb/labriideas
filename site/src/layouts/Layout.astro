---
// Imports
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Player from '../components/Player.svelte';

// Get the current URL path to highlight the active link
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Labri Ideas</title>
		<ClientRouter /> 
	</head>
	<body class="bg-slate-900 text-white min-h-screen flex flex-col">
		<!-- Navigation Menu -->
		<nav class="bg-slate-800 border-b border-slate-700 px-6 py-4 flex gap-6">
			<a href="/labri-home" class={`text-lg font-semibold hover:text-cyan-300 transition-colors ${currentPath === '/labri-home' ? 'text-cyan-400' : 'text-slate-300'}`}>
				Home
			</a>
			<a href="/viewCatalog" class={`text-lg font-semibold hover:text-cyan-300 transition-colors ${currentPath === '/viewCatalog' ? 'text-cyan-400' : 'text-slate-300'}`}>
				View Catalog
			</a>
			<a href="/admin" class={`text-lg font-semibold hover:text-cyan-300 transition-colors ${currentPath === '/catalog' ? 'text-cyan-400' : 'text-slate-300'}`}>
				Admin
			</a>
		</nav>

		<!-- Main Content -->
		<main class="flex-1 p-8 pb-32">
			<slot />
		</main>

		<!-- PLAYER: Visible on all pages, controls its own visibility -->
		<div transition:persist="audio-player">
			<Player 
			client:load 
			showTracklist={false} 
			apiBase="http://localhost:8080" 
			isAdmin={true} 
			/>
		</div>
	</body>
</html>
